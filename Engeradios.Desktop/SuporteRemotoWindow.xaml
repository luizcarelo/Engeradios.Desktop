<Window x:Class="Engeradios.Desktop.SuporteRemotoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suporte Remoto - Engeradios C3" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" Background="#0F0F0F" FontFamily="Segoe UI"
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SUPORTE TÉCNICO REMOTO" Foreground="White" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Forneça as credenciais abaixo ao técnico da Engeradios para permitir o acesso temporário e seguro à máquina." Foreground="#888888" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Credenciais -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Padding="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="O SEU ID DE ACESSO" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtIdAcesso" Text="000 000 000" Foreground="White" FontSize="36" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="PALAVRA-PASSE TEMPORÁRIA" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtSenhaAcesso" Text="0000" Foreground="#CC0000" FontSize="36" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🟢" Foreground="LimeGreen" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="Aguardando ligação do técnico..." Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Botões -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnGerarNovaSenha" Grid.Column="0" Content="🔄 NOVA SENHA" Height="40" Background="#2A2A2A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnGerarNovaSenha_Click"/>
            <Button x:Name="BtnCopiar" Grid.Column="2" Content="📋 COPIAR DADOS" Height="40" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnCopiar_Click"/>
        </Grid>
    </Grid>
</Window>