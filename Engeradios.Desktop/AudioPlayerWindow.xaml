<Window x:Class="Engeradios.Desktop.AudioPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reprodutor de Áudio - Engeradios C3" Height="220" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" ResizeMode="NoResize"
        WindowStyle="ToolWindow" Closing="Window_Closing">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="TxtCanal" Text="Canal: Desconhecido" Foreground="White" FontWeight="Bold" FontSize="16"/>
            <TextBlock x:Name="TxtData" Text="Data da Gravação" Foreground="#AAAAAA" FontSize="12"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <Slider x:Name="SldProgresso" Minimum="0" Maximum="100" Value="0" IsMoveToPointEnabled="True" 
                    Thumb.DragStarted="SldProgresso_DragStarted" Thumb.DragCompleted="SldProgresso_DragCompleted" ValueChanged="SldProgresso_ValueChanged"/>
            <Grid Margin="0,5,0,0">
                <TextBlock x:Name="TxtTempoAtual" Text="00:00" Foreground="#AAAAAA" HorizontalAlignment="Left"/>
                <TextBlock x:Name="TxtTempoTotal" Text="00:00" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnPlayPause" Content="⏸ PAUSAR" Width="120" Height="40" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnPlayPause_Click"/>
        </StackPanel>
    </Grid>
</Window>