<Window x:Class="Engeradios.Desktop.CadastroUsuariosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestão de Utilizadores - Engeradios C3" Height="500" Width="800"
        WindowStartupLocation="CenterOwner" Background="#0F0F0F" FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="CONTROLO DE ACESSO" Foreground="White" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Adicione novos operadores e administradores ou remova acessos antigos." Foreground="#888888" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Painel Esquerdo: Criar Novo -->
            <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <StackPanel>
                    <TextBlock Text="ADICIONAR UTILIZADOR" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="NOME DE UTILIZADOR" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtNovoUsername" Height="35" Background="#2A2A2A" Foreground="White" BorderBrush="#444444" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="PALAVRA-PASSE" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="TxtNovaPassword" Height="35" Background="#2A2A2A" Foreground="White" BorderBrush="#444444" Padding="8,0" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="NÍVEL DE ACESSO" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbNivelAcesso" Height="35" Background="#2A2A2A" Foreground="Black" Padding="8,5" Margin="0,0,0,25">
                        <ComboBoxItem Content="Operador" IsSelected="True"/>
                        <ComboBoxItem Content="Administrador"/>
                    </ComboBox>

                    <Button x:Name="BtnSalvar" Content="GRAVAR UTILIZADOR" Height="40" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSalvar_Click"/>
                </StackPanel>
            </Border>

            <!-- Painel Direito: Lista -->
            <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="UTILIZADORES REGISTADOS" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <DataGrid x:Name="GridUsuarios" Grid.Row="1" Background="#1E1E1E" BorderThickness="0" 
                              RowHeight="35" RowBackground="#1E1E1E" AlternatingRowBackground="#252525" 
                              Foreground="White" HeadersVisibility="Column" AutoGenerateColumns="False" 
                              IsReadOnly="True" GridLinesVisibility="None" SelectionMode="Single">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Utilizador" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Permissões" Binding="{Binding NivelAcesso}" Width="130"/>

                            <DataGridTemplateColumn Header="Ações" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Apagar" Background="Transparent" Foreground="#CC0000" BorderThickness="0" Cursor="Hand" CommandParameter="{Binding}" Click="BtnApagar_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>