<Window x:Class="Engeradios.Desktop.ConfiguracoesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações do Sistema - Engeradios" Height="450" Width="700"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" FontFamily="Segoe UI"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Mapeamento de Hardware e Canais" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Associe as placas de som físicas aos canais de gravação e defina a sensibilidade." Foreground="#AAAAAA" FontSize="14"/>
        </StackPanel>

        <!-- Tabela de Configuração -->
        <Border Grid.Row="1" Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <!-- Nome do Canal -->
                    <ColumnDefinition Width="*"/>
                    <!-- Placa de Som -->
                    <ColumnDefinition Width="150"/>
                    <!-- Sensibilidade -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <!-- Cabeçalhos -->
                    <RowDefinition Height="50"/>
                    <!-- Canal 1 -->
                    <RowDefinition Height="50"/>
                    <!-- Canal 2 -->
                    <RowDefinition Height="50"/>
                    <!-- Canal 3 -->
                </Grid.RowDefinitions>

                <!-- Títulos das Colunas -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome do Canal" Foreground="#AAAAAA" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Placa de Áudio (Entrada)" Foreground="#AAAAAA" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Squelch (VAD)" Foreground="#AAAAAA" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <!-- LINHA 1: Canal 1 -->
                <TextBox x:Name="TxtCanal1" Grid.Row="1" Grid.Column="0" Text="Segurança" VerticalAlignment="Center" Padding="5" Background="#1E1E1E" Foreground="White" BorderBrush="#555555"/>
                <ComboBox x:Name="CmbPlaca1" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0" Padding="5" Background="#1E1E1E" Foreground="Black"/>
                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Slider x:Name="SldCanal1" Width="90" Minimum="0" Maximum="1" Value="0.05" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblSld1" Text="5%" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- LINHA 2: Canal 2 -->
                <TextBox x:Name="TxtCanal2" Grid.Row="2" Grid.Column="0" Text="Manutenção" VerticalAlignment="Center" Padding="5" Background="#1E1E1E" Foreground="White" BorderBrush="#555555"/>
                <ComboBox x:Name="CmbPlaca2" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0" Padding="5" Background="#1E1E1E" Foreground="Black"/>
                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Slider x:Name="SldCanal2" Width="90" Minimum="0" Maximum="1" Value="0.05" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblSld2" Text="5%" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- LINHA 3: Canal 3 -->
                <TextBox x:Name="TxtCanal3" Grid.Row="3" Grid.Column="0" Text="Brigada" VerticalAlignment="Center" Padding="5" Background="#1E1E1E" Foreground="White" BorderBrush="#555555"/>
                <ComboBox x:Name="CmbPlaca3" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0" Padding="5" Background="#1E1E1E" Foreground="Black"/>
                <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Slider x:Name="SldCanal3" Width="90" Minimum="0" Maximum="1" Value="0.05" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="LblSld3" Text="5%" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Botões de Ação -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button x:Name="BtnCancelar" Content="CANCELAR" Width="100" Height="40" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Click="BtnCancelar_Click"/>
            <Button x:Name="BtnSalvar" Content="SALVAR CONFIGURAÇÕES" Width="200" Height="40" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand" Click="BtnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Window>