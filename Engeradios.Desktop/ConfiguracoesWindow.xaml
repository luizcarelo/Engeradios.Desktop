<!-- Caminho do arquivo: Engeradios.Desktop/ConfiguracoesWindow.xaml -->
<Window x:Class="Engeradios.Desktop.ConfiguracoesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações do Sistema" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing"
        FontFamily="Segoe UI"
        Background="#F4F6F8">

    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CONFIGURAÇÕES GERAIS E HARDWARE" Style="{StaticResource HeaderStyle}" Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Bloco de Configurações Gerais -->
                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20" BorderBrush="#E1DFDD" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Armazenamento Local" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Limite de Espaço em Disco para Gravações:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="CmbLimiteDisco" Width="120" Padding="4">
                                <ComboBoxItem Content="20 GB" Tag="20" />
                                <ComboBoxItem Content="40 GB" Tag="40" />
                                <ComboBoxItem Content="60 GB" Tag="60" />
                                <ComboBoxItem Content="100 GB" Tag="100" />
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="Quando este limite for atingido, o sistema apagará automaticamente os áudios mais antigos que não estiverem protegidos (FIFO)." 
                                   Foreground="Gray" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Bloco de Hardware (Canais) -->
                <Border Background="White" CornerRadius="8" Padding="15" BorderBrush="#E1DFDD" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Configuração de Canais de Rádio" Style="{StaticResource SubHeaderStyle}" Margin="0" Grid.Column="0" VerticalAlignment="Center"/>
                            <Button Content="+ ADICIONAR CANAL" Grid.Column="1" Padding="10,5" Background="#107C10" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnAdicionar_Click"/>
                        </Grid>

                        <ItemsControl x:Name="ListaCanaisUI">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB" CornerRadius="6" Padding="15" Margin="0,0,0,10" BorderBrush="#E1DFDD" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="Nome do Canal:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Width="200" Padding="4"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="Placa de Áudio:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <ComboBox ItemsSource="{Binding DataContext.DispositivosDisponiveis, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                              DisplayMemberPath="Nome" SelectedValuePath="Index" SelectedValue="{Binding PlacaIndex}" 
                                                              Width="280" Padding="4" SelectionChanged="ComboBox_SelectionChanged"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="Ganho/Volume:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <Slider Minimum="0.1" Maximum="3.0" Value="{Binding Volume}" Width="150" VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                                                    <TextBlock Text="{Binding VolumePercent}" Margin="10,0,0,0" VerticalAlignment="Center" Width="40"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="Sensibilidade (VAD):" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <Slider Minimum="0.01" Maximum="0.5" Value="{Binding VAD}" Width="150" VerticalAlignment="Center" TickFrequency="0.01" IsSnapToTickEnabled="True"/>
                                                    <TextBlock Text="{Binding VADPercent}" Margin="10,0,0,0" VerticalAlignment="Center" Width="40"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Teste de Áudio:" Width="120" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <ProgressBar Value="{Binding NivelAudio}" Maximum="100" Width="200" Height="10" Foreground="{Binding CorBarraAudio}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="✕ Remover" Background="Transparent" Foreground="#D13438" FontWeight="Bold" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top" CommandParameter="{Binding}" Click="BtnRemoverCanal_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="CANCELAR" Width="100" Padding="8" Margin="0,0,10,0" Background="Transparent" BorderBrush="#8A8886" BorderThickness="1" Cursor="Hand" Click="BtnCancelar_Click"/>
            <Button Content="SALVAR DEFINIÇÕES" Width="150" Padding="8" Background="#005A9E" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Window>