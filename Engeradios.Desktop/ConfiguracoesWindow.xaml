<Window x:Class="Engeradios.Desktop.ConfiguracoesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestão de Hardware e Canais - Engeradios C3" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#0F0F0F" FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="MAPEAMENTO DINÂMICO DE HARDWARE" Foreground="White" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Adicione canais, vincule placas de áudio físicas e teste os níveis de entrada (Squelch) em tempo real." Foreground="#888888" FontSize="13" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Lista Dinâmica de Canais (ItemsControl) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#151515" Padding="15">
            <ItemsControl x:Name="ListaCanaisUI">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,15" Padding="15,15" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Botão Remover -->
                                    <ColumnDefinition Width="220"/>
                                    <!-- Nome -->
                                    <ColumnDefinition Width="250"/>
                                    <!-- Placa -->
                                    <ColumnDefinition Width="160"/>
                                    <!-- VAD -->
                                    <ColumnDefinition Width="160"/>
                                    <!-- Volume -->
                                    <ColumnDefinition Width="*"/>
                                    <!-- VU Meter -->
                                </Grid.ColumnDefinitions>

                                <!-- Botão Remover (X) -->
                                <Button Grid.Column="0" Content="✕" Width="30" Height="30" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0"
                                        CommandParameter="{Binding}" Click="BtnRemoverCanal_Click" ToolTip="Remover este canal"/>

                                <!-- Nome do Canal -->
                                <StackPanel Grid.Column="1" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Text="NOME DO CANAL:" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Nome}" Padding="8,5" Background="#2A2A2A" Foreground="White" BorderBrush="#444444" Height="32" VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Seleção de Placa -->
                                <StackPanel Grid.Column="2" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Text="PLACA DE ENTRADA (HARDWARE):" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding DataContext.DispositivosDisponiveis, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Nome" SelectedValuePath="Index" SelectedValue="{Binding PlacaIndex}" 
                                              Padding="8,5" Background="#2A2A2A" Foreground="Black" Height="32" VerticalContentAlignment="Center"
                                              SelectionChanged="ComboBox_SelectionChanged"/>
                                </StackPanel>

                                <!-- VAD (Squelch) -->
                                <StackPanel Grid.Column="3" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Text="VAD (CORTE SILÊNCIO):" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="32">
                                        <Slider Value="{Binding VAD}" Minimum="0" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" Width="90" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VADPercent}" Foreground="White" FontWeight="SemiBold" Margin="10,0,0,0" Width="40" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Volume (Ganho) -->
                                <StackPanel Grid.Column="4" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <TextBlock Text="GANHO (VOLUME):" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="32">
                                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="2" TickFrequency="0.1" IsSnapToTickEnabled="True" Width="90" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding VolumePercent}" Foreground="White" FontWeight="SemiBold" Margin="10,0,0,0" Width="45" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- VU Meter (Barra de Áudio em Tempo Real) -->
                                <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                    <TextBlock Text="SINAL EM TEMPO REAL" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                    <!-- CORREÇÃO: CornerRadius removido, pois ProgressBar não o suporta nativamente no WPF -->
                                    <ProgressBar Value="{Binding NivelAudio}" Maximum="100" Height="12" Background="#111111" Foreground="{Binding CorBarraAudio}" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Botão Adicionar Novo -->
        <Button x:Name="BtnAdicionar" Grid.Row="2" Content="+ ADICIONAR NOVO CANAL" Width="220" Height="38" Background="#2A2A2A" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Margin="0,15,0,0" Cursor="Hand" HorizontalAlignment="Left" Click="BtnAdicionar_Click"/>

        <!-- Botões Salvar / Cancelar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button x:Name="BtnCancelar" Content="CANCELAR" Width="100" Height="40" Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" Click="BtnCancelar_Click"/>
            <Button x:Name="BtnSalvar" Content="SALVAR CONFIGURAÇÕES" Width="220" Height="40" Background="#CC0000" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand" Click="BtnSalvar_Click"/>
        </StackPanel>
    </Grid>
</Window>