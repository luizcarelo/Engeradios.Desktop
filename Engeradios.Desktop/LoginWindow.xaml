<!-- Caminho do arquivo: Engeradios.Desktop/LoginWindow.xaml -->
<Window x:Class="Engeradios.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="JanelaLogin"
        Title="Engeradios Gravador - Login" Height="520" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="Transparent">

    <Window.Resources>
        <!-- Estilo moderno para o botão de Login -->
        <Style x:Key="ModernLoginButton" TargetType="Button">
            <Setter Property="Background" Value="#005A9E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="FundoBorder" Background="#0F0F0F" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <!-- Botões de Janela (Fechar e Tema) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,10,10,0">
                <Button x:Name="BtnTema" Content="🌙" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="16" Cursor="Hand" Click="BtnTema_Click" ToolTip="Alternar Tema" Margin="0,0,10,0"/>
                <Button x:Name="BtnSair" Content="✕" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="16" Cursor="Hand" Click="BtnSair_Click" ToolTip="Encerrar Sistema"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                <!-- Imagem Dinâmica da Logo -->
                <Image x:Name="ImgLogo" Height="70" Margin="0,0,0,30" RenderOptions.BitmapScalingMode="HighQuality"/>

                <TextBlock x:Name="TxtTitulo" Text="AUTENTICAÇÃO" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="TxtSubtitulo" Text="Insira suas credenciais para continuar" Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Campo Utilizador -->
                <TextBlock x:Name="LblUsuario" Text="Utilizador" Foreground="LightGray" FontSize="12" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border x:Name="BordaUsuario" Background="#1E1E1E" CornerRadius="4" Padding="10,8" Margin="0,0,0,15" BorderBrush="#333" BorderThickness="1">
                    <TextBox x:Name="TxtUsuario" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" CaretBrush="White"/>
                </Border>

                <!-- Campo Palavra-Passe -->
                <TextBlock x:Name="LblSenha" Text="Palavra-passe" Foreground="LightGray" FontSize="12" Margin="0,0,0,5" FontWeight="SemiBold"/>
                <Border x:Name="BordaSenha" Background="#1E1E1E" CornerRadius="4" Padding="10,8" Margin="0,0,0,20" BorderBrush="#333" BorderThickness="1">
                    <PasswordBox x:Name="TxtSenha" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" CaretBrush="White" KeyDown="TxtSenha_KeyDown"/>
                </Border>

                <!-- Campo Confirmação de Senha: usado somente na primeira instalação -->
                <TextBlock x:Name="LblConfirmarSenha"
           Text="Confirmar nova senha"
           Foreground="LightGray"
           FontSize="12"
           Margin="0,0,0,5"
           FontWeight="SemiBold"
           Visibility="Collapsed"/>

                <Border x:Name="BordaConfirmarSenha"
        Background="#1E1E1E"
        CornerRadius="4"
        Padding="10,8"
        Margin="0,0,0,15"
        BorderBrush="#333"
        BorderThickness="1"
        Visibility="Collapsed">
                    <PasswordBox x:Name="TxtConfirmarSenha"
                 Background="Transparent"
                 Foreground="White"
                 BorderThickness="0"
                 FontSize="14"
                 CaretBrush="White"
                 KeyDown="TxtSenha_KeyDown"/>
                </Border>

                <!-- Mensagem de Erro (Oculta por padrão) -->
                <TextBlock x:Name="TxtErro" Text="Credenciais inválidas." Foreground="#D13438" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed" FontWeight="SemiBold"/>

                <!-- Botão Entrar -->
                <Button x:Name="BtnEntrar" Content="ENTRAR" Style="{StaticResource ModernLoginButton}" Click="BtnEntrar_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>