<Window x:Class="Engeradios.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="JanelaPrincipal"
        Title="Login - Engeradios" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        ResizeMode="NoResize" WindowStyle="None">

    <Border x:Name="BordaPrincipal" BorderBrush="#CC0000" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Botão de Trocar Tema -->
            <Button x:Name="BtnTema" Grid.Row="0" Content="☀️ Tema Claro" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                    Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Click="BtnTema_Click"/>

            <!-- Logótipo da Empresa Corrigido -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Image x:Name="ImgLogo" Source="logo_escuro.png" Height="70" RenderOptions.BitmapScalingMode="HighQuality"/>
            </StackPanel>

            <!-- Formulário de Login -->
            <StackPanel Grid.Row="1" Margin="40,20,40,0">
                <TextBlock x:Name="LblUsuario" Text="Utilizador:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsuario" FontSize="16" Padding="8" Background="#2A2A2A" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,0,0,20"/>

                <TextBlock x:Name="LblSenha" Text="Palavra-passe:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtSenha" FontSize="16" Padding="8" Background="#2A2A2A" Foreground="White" BorderBrush="#444444" BorderThickness="1" Margin="0,0,0,30"/>

                <Button x:Name="BtnLogin" Content="ENTRAR" Height="45" Background="#CC0000" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click"/>

                <TextBlock x:Name="TxtErro" Text="Credenciais inválidas!" Foreground="#FF5555" HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Hidden"/>
            </StackPanel>

            <!-- Botão Sair / Rodapé -->
            <Button x:Name="BtnSair" Grid.Row="2" Content="Sair da Aplicação" Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" Click="BtnSair_Click"/>
        </Grid>
    </Border>
</Window>