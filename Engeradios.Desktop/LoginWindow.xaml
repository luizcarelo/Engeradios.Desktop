<Window x:Class="Engeradios.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Engeradios C3 - Autenticação" Height="450" Width="350"
        WindowStartupLocation="CenterScreen" Background="#0F0F0F" 
        WindowStyle="None" ResizeMode="NoResize" FontFamily="Segoe UI"
        AllowsTransparency="True">

    <Border BorderBrush="#CC0000" BorderThickness="0,3,0,0" Background="#151515">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título / Logótipo Simulado -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
                <!-- CORREÇÃO: Propriedade 'Tracking' removida -->
                <TextBlock Text="ENGERADIOS" Foreground="White" FontSize="24" FontWeight="Black" HorizontalAlignment="Center"/>
                <TextBlock Text="CENTRO DE COMANDO C3" Foreground="#CC0000" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Erro de Login (Invisível por defeito) -->
            <Border x:Name="MsgErro" Grid.Row="1" Background="#4A0000" CornerRadius="4" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                <TextBlock Text="Utilizador ou Palavra-passe incorretos." Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
            </Border>

            <!-- Campos de Login -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <TextBlock Text="UTILIZADOR" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtUsername" Height="40" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" Padding="10,0" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="PALAVRA-PASSE" Foreground="#888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword" Height="40" Background="#1E1E1E" Foreground="White" BorderBrush="#333333" Padding="10,0" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,0,25" KeyDown="TxtPassword_KeyDown"/>

                <Button x:Name="BtnEntrar" Content="ENTRAR NO SISTEMA" Height="45" Background="#CC0000" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnEntrar_Click"/>
            </StackPanel>

            <!-- Rodapé / Botão de Fechar -->
            <Button Grid.Row="3" Content="Encerrar Aplicação" Background="Transparent" Foreground="#666666" BorderThickness="0" Cursor="Hand" Margin="0,20,0,0" Click="BtnSair_Click"/>
        </Grid>
    </Border>
</Window>