<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Engeradios.Desktop.SetupWindow"
        mc:Ignorable="d"
        Title="Configuração de Acesso ao Servidor" Height="300" Width="500"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" 
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <StackPanel Margin="30">
        <TextBlock Text="Configuração de Servidor Cloud" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Text="Introduza a sua Chave de API fornecida pela Engeradios para ativar a sincronização e telemetria." Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <TextBox x:Name="TxtApiKey" Height="40" Background="#2A2A2A" Foreground="White" FontSize="16" Padding="5" BorderBrush="#CC0000"/>

        <Button x:Name="BtnAtivar" Content="ATIVAR ACESSO" Height="45" Background="#CC0000" Foreground="White" FontWeight="Bold" Margin="0,20,0,0" Cursor="Hand" Click="BtnAtivar_Click"/>
    </StackPanel>
</Window>