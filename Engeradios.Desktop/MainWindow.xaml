<!-- Caminho do arquivo: Engeradios.Desktop/MainWindow.xaml -->
<Window x:Class="Engeradios.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="JanelaPrincipal"
        Title="Engeradios Gravador - Centro de Comando" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        FontFamily="Segoe UI"
        Background="#F4F6F8">

    <Window.Resources>
        <!-- Estilo dos Cartões (Cards) -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo dos Botões Principais -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#005A9E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo moderno para botões de ação na tabela -->
        <Style x:Key="AcaoBotao" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo da DataGrid (Tabela) -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E1DFDD"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#D2D0CE"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5F3FF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu Superior -->
        <Menu x:Name="MenuSuperior" DockPanel.Dock="Top" Background="White" Padding="5">
            <MenuItem Header="Sistema" FontSize="14">
                <MenuItem Header="Configurações (Admin)" Click="MenuConfig_Click" />
                <MenuItem Header="Gestão de Nuvem" Click="MenuNuvem_Click" />
                <Separator/>
                <MenuItem Header="Sair" Click="BtnPararEmergencia_Click" />
            </MenuItem>
            <MenuItem Header="Segurança" FontSize="14">
                <MenuItem Header="Cadastro de Utilizadores" Click="MenuCadastro_Click" />
                <MenuItem Header="Auditoria (Logs)" Click="MenuLogs_Click" />
            </MenuItem>
            <MenuItem Header="Visual" FontSize="14">
                <MenuItem x:Name="MenuTema" Header="🌙 Tema Escuro" Click="MenuTema_Click" />
            </MenuItem>
            <MenuItem Header="Ajuda" FontSize="14">
                <MenuItem Header="Verificar Atualizações" Click="MenuAtualizar_Click" />
                <MenuItem Header="Suporte Remoto" Click="MenuRemoto_Click" />
                <MenuItem Header="Portal Engeradios" Click="MenuSuporte_Click" />
            </MenuItem>
        </Menu>

        <!-- Cabeçalho -->
        <Border x:Name="CabecalhoBorder" DockPanel.Dock="Top" Background="White" Padding="20,10" BorderBrush="#E1DFDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="ImgLogoPrincipal" Source="logo_claro.png" Height="40" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="CENTRO DE GRAVAÇÃO - ENGERADIOS" FontSize="20" FontWeight="Bold" Foreground="#323130"/>
                    <TextBlock Text="Sistema de Gravação Automática de Rádio-Comunicações" FontSize="12" Foreground="#605E5C"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#107C10" Margin="0,0,8,0"/>
                    <TextBlock Text="Operador:" Foreground="#605E5C" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtOperadorLogado" Text="{Binding NomeUsuarioLogado}" FontWeight="Bold" Foreground="#323130" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Corpo Principal -->
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO: Monitorização em Tempo Real -->
            <Border x:Name="PainelEsquerdo" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="CANAIS EM MONITORAÇÃO" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <!-- Lista de VU Meters -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaCanaisAtivos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB" CornerRadius="6" Padding="10" Margin="0,0,0,10" BorderBrush="#E1DFDD" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0">
                                                <Ellipse Width="8" Height="8" Fill="{Binding CorAtividade}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding NomeCanal}" FontWeight="Bold" FontSize="14"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StatusTexto}" Foreground="{Binding CorAtividade}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                            <!-- VU Meter (Barra de Som Fluida) -->
                                            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                                         Value="{Binding NivelSinal}" Maximum="100" 
                                                         Height="6" Margin="0,10,0,0" 
                                                         Foreground="{Binding CorAtividade}" Background="#E1DFDD" BorderThickness="0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button x:Name="BtnPararEmergencia" Grid.Row="2" Style="{StaticResource ModernButton}" Background="#D13438" Content="PARAR MOTORES (EMERGÊNCIA)" Margin="0,15,0,0" Click="BtnPararEmergencia_Click"/>
                </Grid>
            </Border>

            <!-- PAINEL DIREITO: Dashboard e Histórico -->
            <Grid Grid.Column="1" x:Name="PainelDireito">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cards de Métricas -->
                <UniformGrid Columns="4" Grid.Row="0">
                    <Border x:Name="Card1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="ESTADO DO SISTEMA" FontSize="11" Foreground="#605E5C" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse x:Name="LedGravando" Width="14" Height="14" Fill="Gray" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtGravando" Text="A INICIAR" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtCanaisAtivos" Text="0 Canais Alocados" FontSize="12" Foreground="#605E5C" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Card2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="CLOUD SYNC" FontSize="11" Foreground="#605E5C" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Ellipse x:Name="LedNuvem" Width="14" Height="14" Fill="Orange" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtEstadoNuvem" Text="A Verificar..." FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Última sincronização: Agora" FontSize="12" Foreground="#605E5C" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Card3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="ARMAZENAMENTO LOCAL" FontSize="11" Foreground="#605E5C" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtUsoDisco" Text="0.0 GB / 40.0 GB" FontSize="16" FontWeight="Bold" Margin="0,5,0,0"/>
                            <ProgressBar x:Name="BarraDisco" Height="6" Margin="0,8,0,0" Foreground="#0078D4" Background="#E1DFDD" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Card4" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ÁUDIOS GRAVADOS HOJE" FontSize="11" Foreground="#605E5C" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtAudiosHoje" Text="0" FontSize="24" FontWeight="Bold" Foreground="#0078D4" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Área de Histórico (Tabela) -->
                <Border Style="{StaticResource CardStyle}" Grid.Row="1" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filtros -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="HISTÓRICO RECENTE (150 MÁX)" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="Data:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <DatePicker x:Name="DpDataFiltro" Width="120" Margin="0,0,15,0" SelectedDateChanged="DpDataFiltro_SelectedDateChanged"/>

                                <TextBlock Text="Pesquisar:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="TxtBusca" Width="180" Padding="4" VerticalContentAlignment="Center" TextChanged="TxtBusca_TextChanged" ToolTip="Pesquise por Canal ou Anotação"/>
                            </StackPanel>
                        </Grid>

                        <!-- Tabela de Dados -->
                        <DataGrid x:Name="GridHistorico" Grid.Row="1">
                            <DataGrid.Columns>
                                <!-- Coluna de Nuvem (Ícone simples textual) -->
                                <DataGridTextColumn Header="Cloud" Binding="{Binding SincronizadoComNuvem, Converter={StaticResource BoolToCloudConverter}}" Width="60" ElementStyle="{StaticResource CenterText}"/>

                                <DataGridTextColumn Header="Data e Hora" Binding="{Binding DataHoraGravacao, StringFormat=\{0:dd/MM/yyyy HH:mm:ss\}}" Width="140"/>
                                <DataGridTextColumn Header="Canal" Binding="{Binding Canal}" Width="120" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Duração (s)" Binding="{Binding DuracaoSegundos}" Width="90"/>

                                <!-- Coluna de Proteção -->
                                <DataGridTextColumn Header="Protegido" Binding="{Binding Protegido, Converter={StaticResource BoolToLockConverter}}" Width="80" ElementStyle="{StaticResource CenterText}"/>

                                <DataGridTextColumn Header="Anotação" Binding="{Binding Anotacoes}" Width="*" />

                                <!-- Botões de Ação -->
                                <DataGridTemplateColumn Header="Ações" Width="260">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource AcaoBotao}" Content="▶ Ouvir" CommandParameter="{Binding}" Click="BtnPlay_Click"/>
                                                <Button Style="{StaticResource AcaoBotao}" Content="✎ Notar" CommandParameter="{Binding}" Click="BtnAnotar_Click"/>
                                                <Button Style="{StaticResource AcaoBotao}" Content="🔒 Proteger" CommandParameter="{Binding}" Click="BtnProteger_Click"/>
                                                <Button Style="{StaticResource AcaoBotao}" Content="💾 Salvar" CommandParameter="{Binding}" Click="BtnExportar_Click"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>