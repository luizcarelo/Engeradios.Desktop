<Window x:Class="Engeradios.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="JanelaPrincipal"
        Title="Engeradios C3 - Centro de Comando e Controlo" Height="768" Width="1366"
        WindowState="Maximized" WindowStartupLocation="CenterScreen" 
        Background="#0F0F0F" FontFamily="Segoe UI" Closing="Window_Closing">

    <Window.Resources>
        <!-- Conversor de Boolean para Visibilidade (Exibe a nuvem verde) -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Menu -->
            <RowDefinition Height="70"/>
            <!-- 1: Header / Logo -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Cards de Resumo -->
            <RowDefinition Height="*"/>
            <!-- 3: Conteúdo Principal -->
            <RowDefinition Height="35"/>
            <!-- 4: Rodapé -->
        </Grid.RowDefinitions>

        <!-- MENU SUPERIOR -->
        <Menu x:Name="MenuSuperior" Grid.Row="0" Background="#1A1A1A" Foreground="White" Padding="10,5">
            <MenuItem x:Name="MenuConfig" Header="⚙️ _Configurações" Click="MenuConfig_Click">
                <MenuItem Header="Mapeamento de Placas e Canais"/>
                <MenuItem Header="Sensibilidade (Squelch) e Volume"/>
                <Separator/>
                <MenuItem Header="Cadastro de Usuários" Click="MenuCadastro_Click"/>
                <MenuItem Header="Log de Auditoria" Click="MenuLogs_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuAjuda" Header="❓ _Suporte">
                <MenuItem Header="Verificar Atualizações" Click="MenuAtualizar_Click"/>
                <MenuItem Header="Suporte Online" Click="MenuSuporte_Click"/>
                <MenuItem Header="Acesso Remoto" Click="MenuRemoto_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuTema" Header="☀️ Tema Claro" Click="MenuTema_Click" HorizontalAlignment="Right" Margin="20,0,0,0"/>
        </Menu>

        <!-- HEADER DA APLICAÇÃO -->
        <Border x:Name="CabecalhoBorder" Grid.Row="1" Background="#151515" BorderBrush="#CC0000" BorderThickness="0,0,0,3">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="ImgLogoPrincipal" Grid.Column="0" Height="45" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OPERADOR LOGADO:" Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock x:Name="TxtOperadorLogado" Text="Admin" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <Border Background="#2A2A2A" CornerRadius="4" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="LedNuvem" Width="10" Height="10" Fill="#CC0000" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtEstadoNuvem" Text="Nuvem: A Ligar..." Foreground="White" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CARDS DE RESUMO (DASHBOARD) -->
        <Grid Grid.Row="2" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Estado da Gravação -->
            <Border x:Name="Card1" Grid.Column="0" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <StackPanel>
                    <TextBlock Text="STATUS DO SISTEMA" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Ellipse x:Name="LedGravando" Width="14" Height="14" Fill="#CC0000" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtGravando" Text="GRAVAÇÃO ATIVA" Foreground="#CC0000" FontWeight="Bold" FontSize="16" Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtCanaisAtivos" Text="3 Canais em Monitorização" Foreground="#888888" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2: Áudios Hoje -->
            <Border x:Name="Card2" Grid.Column="2" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <StackPanel>
                    <TextBlock Text="ÁUDIOS CAPTURADOS HOJE" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtAudiosHoje" Text="0" Foreground="White" FontWeight="Bold" FontSize="22" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3: Espaço em Disco -->
            <Border x:Name="Card3" Grid.Column="4" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <StackPanel>
                    <TextBlock Text="ARMAZENAMENTO LOCAL" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="BarraDisco" Height="8" Minimum="0" Maximum="40" Value="0" Foreground="#CC0000" Background="#333333" BorderThickness="0" Margin="0,10,0,5"/>
                    <TextBlock x:Name="TxtUsoDisco" Text="Calculando..." Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Card 4: Sincronização -->
            <Border x:Name="Card4" Grid.Column="6" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <StackPanel>
                    <TextBlock Text="FILA DE UPLOAD (NUVEM)" Foreground="#AAAAAA" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Text="Sincronização em Background" Foreground="LimeGreen" FontWeight="Bold" FontSize="14" Margin="0,5,0,0"/>
                    <TextBlock Text="Totalmente Automatizado" Foreground="#888888" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ÁREA PRINCIPAL DIVIDIDA -->
        <Grid Grid.Row="3" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO: Telemetria em Tempo Real -->
            <Border x:Name="PainelEsquerdo" Grid.Column="0" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="TELEMETRIA DE ÁUDIO" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                    <!-- Simulação do Espectro embutido -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Sinal de Entrada Global" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="100">
                            <Rectangle x:Name="BarraA1" Width="15" Height="10" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="BarraA2" Width="15" Height="25" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="BarraA3" Width="15" Height="15" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="BarraA4" Width="15" Height="60" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="BarraA5" Width="15" Height="40" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="BarraA6" Width="15" Height="80" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                            <Rectangle x:Name="BarraA7" Width="15" Height="30" Fill="#CC0000" Margin="4,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="BtnPararEmergencia" Grid.Row="2" Content="PARAR MOTORES (EMERGÊNCIA)" Background="#444444" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnPararEmergencia_Click"/>
                </Grid>
            </Border>

            <!-- PAINEL DIREITO: Gestão de Gravações -->
            <Border x:Name="PainelDireito" Grid.Column="2" Background="#1E1E1E" CornerRadius="6" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de Filtros -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="HISTÓRICO DE GRAVAÇÕES" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                        <!-- Campos de Busca -->
                        <TextBox x:Name="TxtBusca" Grid.Column="2" Padding="8,5" Background="#2A2A2A" Foreground="White" BorderBrush="#444444" Margin="0,0,10,0" VerticalContentAlignment="Center" TextChanged="TxtBusca_TextChanged"/>
                        <TextBlock Grid.Column="2" Text="🔍 Procurar Canal..." Foreground="#777777" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>

                        <DatePicker x:Name="DpDataFiltro" Grid.Column="3" Background="#2A2A2A" Foreground="Black" SelectedDateChanged="DpDataFiltro_SelectedDateChanged"/>
                    </Grid>

                    <!-- Grelha Profissional -->
                    <DataGrid x:Name="GridHistorico" Grid.Row="1" Background="#1E1E1E" BorderThickness="0" 
                              RowHeight="40" RowBackground="#1E1E1E" AlternatingRowBackground="#252525" 
                              Foreground="White" HeadersVisibility="Column" AutoGenerateColumns="False" 
                              IsReadOnly="True" GridLinesVisibility="None" SelectionMode="Single">

                        <!-- Estilo moderno para o cabeçalho -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Data / Hora" Binding="{Binding DataHoraGravacao, StringFormat=\{0:dd/MM/yyyy HH:mm:ss\}}" Width="160"/>
                            <DataGridTextColumn Header="Canal" Binding="{Binding Canal}" Width="150"/>
                            <DataGridTextColumn Header="Duração" Binding="{Binding DuracaoSegundos, StringFormat=\{0\} seg}" Width="100"/>

                            <!-- Novo Indicador Visual de Proteção (Marcado) -->
                            <DataGridTemplateColumn Header="Salvo" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="⭐" Foreground="Gold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding Protegido, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Protegido contra Limpeza Automática"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Indicador de Nuvem usando Emoji -->
                            <DataGridTemplateColumn Header="Nuvem" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="☁️" Foreground="LimeGreen" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding SincronizadoComNuvem, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Anotações" Binding="{Binding Anotacoes}" Width="*"/>

                            <!-- Nova Coluna de Ações atualizada -->
                            <DataGridTemplateColumn Header="Ações" Width="320">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="⭐ Proteger" Background="Transparent" Foreground="Gold" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" CommandParameter="{Binding}" Click="BtnProteger_Click"/>
                                            <Button Content="📝 Anotar" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" CommandParameter="{Binding}" Click="BtnAnotar_Click"/>
                                            <Button Content="▶️ Ouvir" Background="Transparent" Foreground="LightSkyBlue" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" CommandParameter="{Binding}" Click="BtnPlay_Click"/>
                                            <Button Content="💾 Exportar" Background="Transparent" Foreground="Orange" BorderThickness="0" Cursor="Hand" CommandParameter="{Binding}" Click="BtnExportar_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- RODAPÉ COMPACTO -->
        <Border Grid.Row="4" Background="#0C0C0C" BorderBrush="#222222" BorderThickness="0,1,0,0">
            <TextBlock Text="Engeradios Cloud Sync v2.0 - Sistema Protegido por Criptografia DPAPI" Foreground="#555555" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>