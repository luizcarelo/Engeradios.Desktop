<Window x:Class="Engeradios.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="JanelaPrincipal"
        Title="Engeradios - Sistema de Gravação e Telemetria" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Menu x:Name="MenuSuperior" Grid.Row="0" Background="#2A2A2A" Foreground="White" Padding="5,2">
            <MenuItem x:Name="MenuConfig" Header="_Configurações" Click="MenuConfig_Click">
                <MenuItem Header="Mapeamento de Placas e Canais"/>
                <MenuItem Header="Sensibilidade (Squelch) e Volume"/>
                <MenuItem Header="Cadastro de Usuários"/>
                <MenuItem Header="Log de Usuários"/>
            </MenuItem>
            <MenuItem x:Name="MenuAjuda" Header="_Ajuda">
                <MenuItem Header="Verificar Atualizações" Click="MenuAtualizar_Click"/>
                <Separator/>
                <MenuItem Header="Suporte Online" Click="MenuSuporte_Click"/>
                <MenuItem Header="Conexão Remota (Suporte Técnico)" Click="MenuRemoto_Click"/>
            </MenuItem>
            <MenuItem x:Name="MenuTema" Header="☀️ Tema Claro" Click="MenuTema_Click" HorizontalAlignment="Right" Margin="20,0,0,0"/>
        </Menu>

        <Border x:Name="CabecalhoBorder" Grid.Row="1" Background="#000000" BorderBrush="#CC0000" BorderThickness="0,0,0,4">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="ImgLogoPrincipal" Source="logo_escuro.png" Height="60" RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="LedNuvem" Width="12" Height="12" Fill="#CC0000" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtEstadoNuvem" Text="Nuvem: Offline" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="AreaControlos" Grid.Row="2" Margin="20" Background="#2A2A2A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="15" VerticalAlignment="Center">
                <TextBlock x:Name="LblCanais" Text="Canais em Gravação Automática:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                <TextBlock x:Name="LblCanaisLista" Text="• Segurança (Placa Primária)&#x0a;• Manutenção (Placa USB 1)&#x0a;• Brigada (Placa USB 2)" Foreground="White" FontWeight="SemiBold" FontSize="14" Margin="5,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,25" Height="60">
                <Rectangle x:Name="BarraA1" Width="12" Height="10" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA2" Width="12" Height="25" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA3" Width="12" Height="15" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA4" Width="12" Height="40" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA5" Width="12" Height="20" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA6" Width="12" Height="50" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA7" Width="12" Height="15" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
                <Rectangle x:Name="BarraA8" Width="12" Height="30" Fill="#CC0000" Margin="3,0" VerticalAlignment="Bottom" RadiusX="3" RadiusY="3"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="15" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse x:Name="LedGravando" Width="16" Height="16" Fill="#CC0000" Margin="0,0,10,0"/>
                <TextBlock x:Name="TxtGravando" Text="GRAVANDO..." Foreground="#CC0000" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <GroupBox x:Name="GrupoHistorico" Grid.Row="3" Header="Histórico de Áudios Locais" Foreground="White" Margin="20,0,20,10" BorderBrush="#444444">
            <DataGrid x:Name="GridHistorico" Background="#1E1E1E" AlternatingRowBackground="#2A2A2A" RowBackground="#1E1E1E" 
                      Foreground="Black" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#444444">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Data e Hora" Binding="{Binding DataHoraGravacao, StringFormat=\{0:dd/MM/yyyy HH:mm:ss\}}" Width="150"/>
                    <DataGridTextColumn Header="Canal" Binding="{Binding Canal}" Width="120"/>
                    <DataGridTextColumn Header="Duração (seg)" Binding="{Binding DuracaoSegundos}" Width="100"/>
                    <DataGridTextColumn Header="Anotações" Binding="{Binding Anotacoes}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Sinc. Nuvem" Binding="{Binding SincronizadoComNuvem}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border x:Name="RodapeBorder" Grid.Row="4" Background="#121212" BorderBrush="#333333" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblUsoDisco" Text="Uso do Disco (Quota: 40GB):" Foreground="#AAAAAA" Margin="0,0,10,0"/>
                    <ProgressBar x:Name="BarraDisco" Width="200" Height="15" Minimum="0" Maximum="40" Value="1.5" Foreground="#CC0000" Background="#333333"/>
                    <TextBlock x:Name="TxtUsoDisco" Text="1.5 GB / 40 GB" Foreground="White" Margin="10,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="TxtOperadorLogado" Text="Operador" Foreground="#AAAAAA" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>

                <TextBlock Grid.Column="2" x:Name="TxtEstadoGravacao" Text="Modo Contínuo Ativado" Foreground="#AAAAAA" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>